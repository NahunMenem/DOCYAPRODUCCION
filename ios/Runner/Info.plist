    <key>GMSApiKey</key>
    <string>AIzaSyDDxc609CsgE8Yt_IR-K-YO5U8aXqXe1NU</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- 🌐 Seguridad (permite conexiones HTTP internas de desarrollo) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>

    <!-- 📍 Permisos -->
    <key>NSCameraUsageDescription</key>
    <string>DocYa necesita acceder a la cámara para tomar una foto de tu DNI.</string>

    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>DocYa necesita tu ubicación en todo momento para asignarte consultas en tiempo real.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>DocYa necesita tu ubicación en segundo plano para que los pacientes puedan seguirte en el mapa.</string>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>DocYa necesita tu ubicación para mostrarte pacientes cercanos.</string>

    <key>NSPhotoLibraryUsageDescription</key>
    <string>DocYa necesita acceder a tus fotos para adjuntar imágenes de tu DNI.</string>

    <!-- 🖱️ Permite soporte para teclados externos -->
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>

    <!-- 🔔 Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>location</string>
    </array>

    <!-- 🧩 Storyboards -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <!-- 📱 Orientación -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- 📌 Requiere WiFi/GPS (recomendación App Store) -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>location-services</string>
        <string>wifi</string>
    </array>

    <!-- 🔔 Push en producción (APNS) -->
    <key>aps-environment</key>
    <string>production</string>
    <key>NSSupportsLiveActivities</key>
    <true/>

    <!-- ⏰ Notificaciones sensibles al tiempo (pastillero) -->
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.docya.app.medication</string>
    </array>

</dict>
</plist>
